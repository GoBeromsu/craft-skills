# technical-report — per-project paths (copy to .env and fill).
# Never hardcode these in the skill; never commit real .env.

# Path to this project's filled technical-report.yaml (the SSOT frame).
# Keep this at a tool-neutral path (repo root or docs/). Do NOT place under
# .claude/, .codex/, .gjc/, .hermes/, or any other tool-private directory —
# the YAML is read by all agents and must be discoverable by every runtime.
TECHNICAL_REPORT_YAML=./technical-report.yaml

# Directory holding the canonical markdown (Index + section files).
# Source manifests default to <book>/sources.
TECHNICAL_REPORT_BOOK=./book
