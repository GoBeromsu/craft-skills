#!/usr/bin/env sh
# git-guard pre-commit hook.
#   - assert-not-main : refuse commits on a protected branch
#   - deny-assets     : block model weights / media / oversized blobs added to the index
#   - check-freshness : warn (never block) when the branch is behind upstream
#
# This hook only dispatches; all logic lives in scripts/git-guard/ so every actor
# (Claude, Codex, human) enforces identical rules by construction.
set -eu

guard="$(git rev-parse --show-toplevel)/scripts/git-guard"
"$guard/assert-not-main.sh"
"$guard/deny-assets.sh" staged
"$guard/check-freshness.sh" warn
